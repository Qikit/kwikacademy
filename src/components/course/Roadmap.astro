---
interface Node {
  slug: string;
  title: string;
  order: number;
  href: string;
}
interface Props {
  nodes: Node[];
}
const { nodes } = Astro.props;
---

<ol class="roadmap">
  {
    nodes.map((n, i) => (
      <li class="rnode" data-lesson={n.slug}>
        <a href={n.href}>
          <span class="dot" data-state="todo">{n.order}</span>
          <span class="rtitle">{n.title}</span>
        </a>
        {i < nodes.length - 1 && <span class="conn" aria-hidden="true" />}
      </li>
    ))
  }
</ol>

<style>
  .roadmap {
    list-style: none;
    max-width: 560px;
    margin: 0 auto;
    padding: 0;
  }
  .rnode {
    position: relative;
    padding-left: 8px;
  }
  .rnode a {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
  }
  .dot {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
    border: 2px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--text-2);
    transition: all 0.3s;
  }
  .dot[data-state='done'] {
    background: var(--grad-blue-purple);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 0 16px rgba(124, 108, 240, 0.5);
  }
  .dot[data-state='current'] {
    border-color: var(--c-purple);
    color: var(--c-purple);
  }
  .rtitle {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .conn {
    position: absolute;
    left: 27px;
    top: 54px;
    width: 2px;
    height: calc(100% - 40px);
    background: var(--track);
  }
</style>
