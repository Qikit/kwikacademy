---
import Icon from '../ui/Icon.astro';

interface Node {
  slug: string;
  title: string;
  order: number;
  href: string;
  phase?: string;
  placeholder?: boolean;
}
interface Props {
  nodes: Node[];
}
const { nodes } = Astro.props;

// Group consecutively by phase to render phase headers.
let lastPhase: string | undefined;
---

<div class="roadmap">
  {
    nodes.map((n, i) => {
      const showPhase = n.phase && n.phase !== lastPhase;
      lastPhase = n.phase;
      return (
        <>
          {showPhase && <div class="phase-head">{n.phase}</div>}
          <div class="rnode" data-lesson={n.slug}>
            <a href={n.href} class:list={['rcard', { placeholder: n.placeholder }]}>
              <span class="dot" data-state="todo">
                <span class="num">{n.order}</span>
                <span class="tick"><Icon name="check" size={18} /></span>
              </span>
              <span class="rtitle">{n.title}</span>
              {n.placeholder && <span class="soon">скоро</span>}
              <span class="go"><Icon name="chevron-right" size={18} /></span>
            </a>
            {i < nodes.length - 1 && <span class="conn" aria-hidden="true" />}
          </div>
        </>
      );
    })
  }
</div>

<style>
  .roadmap {
    max-width: 600px;
    margin: 0 auto;
  }
  .phase-head {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-purple);
    margin: 32px 0 12px;
    padding-left: 4px;
  }
  .phase-head:first-child {
    margin-top: 0;
  }
  .rnode {
    position: relative;
  }
  .rcard {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 16px;
    margin: 6px 0;
    border-radius: var(--r-md);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .rcard:hover {
    transform: translateX(4px);
    border-color: var(--c-purple);
    box-shadow: 0 10px 30px -18px rgba(124, 108, 240, 0.6);
  }
  .rcard:hover .go {
    color: var(--c-purple);
    transform: translateX(2px);
  }
  .rcard.placeholder {
    opacity: 0.62;
  }
  .dot {
    position: relative;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
    border: 2px solid var(--glass-border);
    background: var(--surface);
    color: var(--text-2);
    transition: all 0.3s;
  }
  .dot .tick {
    display: none;
  }
  .dot[data-state='done'] {
    background: var(--grad-blue-purple);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 0 16px rgba(124, 108, 240, 0.5);
  }
  .dot[data-state='done'] .num {
    display: none;
  }
  .dot[data-state='done'] .tick {
    display: inline-flex;
  }
  .dot[data-state='current'] {
    border-color: var(--c-purple);
    color: var(--c-purple);
  }
  .rtitle {
    flex: 1;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .soon {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-full);
    padding: 3px 9px;
  }
  .go {
    color: var(--text-3);
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }
  .conn {
    position: absolute;
    left: 36px;
    top: 52px;
    width: 2px;
    height: calc(100% - 46px);
    background: var(--track);
    z-index: -1;
  }
</style>
