---
import { getCollection } from 'astro:content';
import CourseCard from '../course/CourseCard.tsx';
import { withBase } from '../../lib/url';

interface Props {
  header?: boolean;
}
const { header = true } = Astro.props;

const courses = (await getCollection('courses'))
  .filter((c) => !c.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const lessons = await getCollection('lessons');
const trainers = await getCollection('trainers');
const lessonsFor = (slug: string) => lessons.filter((l) => l.data.course === slug);
const trainersFor = (slug: string) => trainers.filter((t) => t.data.course === slug);

// Diagonal-brick bento on a 5-column grid. Rows stagger horizontally — row 1
// has a notch at the top-right, row 3 at the bottom-left — so the overall
// silhouette runs diagonally instead of forming a rectangle. Row 2 breaks the
// uniformity with a wide / square / wide sandwich, giving the middle row its
// own rhythm. Cards with the longest content (English, Web titles + Kotlin,
// Java eyebrows) take the 2u wide slots; the others stay 1u squares.
const place: Record<string, { area: string; size: 'lg' | 'md' | 'sm' }> = {
  // Row 1 — wide english, two squares, empty top-right
  english: { area: '1 / 1 / 2 / 3', size: 'lg' }, // cols 1-3
  react: { area: '1 / 3 / 2 / 4', size: 'md' }, // col 3-4
  'ai-llm': { area: '1 / 4 / 2 / 5', size: 'md' }, // col 4-5
  // Row 2 — kotlin / databases / java sandwich, full width
  kotlin: { area: '2 / 1 / 3 / 3', size: 'lg' }, // cols 1-3
  databases: { area: '2 / 3 / 3 / 4', size: 'md' }, // col 3-4
  java: { area: '2 / 4 / 3 / 6', size: 'lg' }, // cols 4-6
  // Row 3 — empty bottom-left, wide web in middle, two squares right
  web: { area: '3 / 2 / 4 / 4', size: 'lg' }, // cols 2-4
  business: { area: '3 / 4 / 4 / 5', size: 'md' }, // col 4-5
  management: { area: '3 / 5 / 4 / 6', size: 'md' }, // col 5-6
};
const fallback = { area: 'auto', size: 'md' as const };
---

<section class="showcase">
  {
    header && (
      <>
        <p class="eyebrow">Каталог</p>
        <h2>Девять направлений, один темп</h2>
      </>
    )
  }
  <div class="bento">
    {
      courses.map((c) => {
        const p = place[c.id] ?? fallback;
        return (
          <div class="cell" style={`grid-area:${p.area}`}>
            <CourseCard
              client:idle
              href={withBase(`/topics/${c.id}`)}
              title={c.data.title}
              eyebrow={c.data.subtitle}
              icon={c.data.icon}
              gradient={c.data.gradient}
              size={p.size}
              meta={`${lessonsFor(c.id).length} ур · ${trainersFor(c.id).length} трен`}
              lessonSlugs={lessonsFor(c.id).map((l) => l.id)}
              trainerSlugs={trainersFor(c.id).map((t) => t.id)}
            />
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .showcase {
    /* slightly wider than the rest of the page — the bento breaks out gently */
    max-width: min(1480px, 94vw);
    margin: 0 auto;
    padding: 8px 24px 110px;
  }
  .eyebrow,
  h2 {
    padding-left: clamp(0px, 4vw, 70px);
  }
  h2 {
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 800;
    margin: 8px 0 40px;
    max-width: 12ch;
  }
  .bento {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-auto-rows: 230px;
    gap: 20px;
  }
  .cell {
    min-width: 0;
    min-height: 0;
  }
  /* tablet: 2-column flow, equal tiles */
  @media (max-width: 920px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
      gap: 24px;
    }
    .cell {
      grid-area: auto !important;
    }
  }
  /* phone: single column */
  @media (max-width: 600px) {
    .bento {
      grid-template-columns: 1fr;
      grid-auto-rows: 200px;
      gap: 22px;
    }
    .eyebrow,
    h2 {
      padding-left: 0;
    }
  }
</style>
