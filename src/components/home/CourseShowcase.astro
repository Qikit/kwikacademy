---
import { getCollection } from 'astro:content';
import CourseCard from '../course/CourseCard.tsx';
import { withBase } from '../../lib/url';

interface Props {
  header?: boolean;
  narrow?: boolean; // catalog uses a tighter container (no break-out)
}
const { header = true, narrow = false } = Astro.props;

const courses = (await getCollection('courses'))
  .filter((c) => !c.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
const lessons = await getCollection('lessons');
const trainers = await getCollection('trainers');
const lessonsFor = (slug: string) => lessons.filter((l) => l.data.course === slug);
const trainersFor = (slug: string) => trainers.filter((t) => t.data.course === slug);

// Brick-like bento on a 6-column grid. Each row is one track tall; wide tiles
// span 2 cols (rectangles), small tiles span 1 col (squares). Rows 1 and 3 are
// centered groups of 3 with 1u padding on each side; row 2 spans full width.
const place: Record<string, { area: string; size: 'lg' | 'md' | 'sm' }> = {
  // Row 1 — centered (cols 2–6): wide + sq + sq
  english: { area: '1 / 2 / 2 / 4', size: 'md' },
  kotlin: { area: '1 / 4 / 2 / 5', size: 'md' },
  java: { area: '1 / 5 / 2 / 6', size: 'md' },
  // Row 2 — full width: 3 wide tiles
  react: { area: '2 / 1 / 3 / 3', size: 'md' },
  'ai-llm': { area: '2 / 3 / 3 / 5', size: 'md' },
  databases: { area: '2 / 5 / 3 / 7', size: 'md' },
  // Row 3 — centered (cols 2–6): wide + sq + sq
  web: { area: '3 / 2 / 4 / 4', size: 'md' },
  business: { area: '3 / 4 / 4 / 5', size: 'md' },
  management: { area: '3 / 5 / 4 / 6', size: 'md' },
};
const fallback = { area: 'auto', size: 'md' as const };
---

<section class={`showcase ${narrow ? 'narrow' : ''}`}>
  {
    header && (
      <>
        <p class="eyebrow">Каталог</p>
        <h2>Девять направлений, один темп</h2>
      </>
    )
  }
  <div class="bento">
    {
      courses.map((c) => {
        const p = place[c.id] ?? fallback;
        return (
          <div class="cell" style={`grid-area:${p.area}`}>
            <CourseCard
              client:idle
              href={withBase(`/topics/${c.id}`)}
              title={c.data.title}
              eyebrow={c.data.subtitle}
              icon={c.data.icon}
              gradient={c.data.gradient}
              size={p.size}
              meta={`${lessonsFor(c.id).length} ур · ${trainersFor(c.id).length} трен`}
              lessonSlugs={lessonsFor(c.id).map((l) => l.id)}
              trainerSlugs={trainersFor(c.id).map((t) => t.id)}
            />
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .showcase {
    /* slightly wider than the rest of the page — the bento breaks out gently */
    max-width: min(1320px, 94vw);
    margin: 0 auto;
    padding: 8px 24px 110px;
  }
  .showcase.narrow {
    /* catalog — stays within the central content column */
    max-width: 1080px;
  }
  .eyebrow,
  h2 {
    padding-left: clamp(0px, 4vw, 70px);
  }
  h2 {
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 800;
    margin: 8px 0 40px;
    max-width: 12ch;
  }
  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 190px;
    gap: 24px;
  }
  .cell {
    min-width: 0;
    min-height: 0;
  }
  /* tablet: 2-column flow, equal tiles */
  @media (max-width: 920px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
      gap: 24px;
    }
    .cell {
      grid-area: auto !important;
    }
  }
  /* phone: single column */
  @media (max-width: 600px) {
    .bento {
      grid-template-columns: 1fr;
      grid-auto-rows: 200px;
      gap: 22px;
    }
    .eyebrow,
    h2 {
      padding-left: 0;
    }
  }
</style>
