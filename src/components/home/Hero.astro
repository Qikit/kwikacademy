---
import Button from '../ui/Button.astro';
import { withBase } from '../../lib/url';
---

<section class="hero">
  <p class="eyebrow">Учись свободно · без регистрации</p>
  <h1>Знания, которые <em>дышат</em></h1>
  <p class="sub">
    Глубокие уроки и живые тренажёры по английскому, коду, ИИ и бизнесу. Прогресс хранится у тебя на устройстве.
  </p>
  <div class="cta">
    <Button href={withBase('/topics')}>Начать →</Button>
    <Button href={withBase('/topics')} variant="glass">Каталог тем</Button>
  </div>
</section>

<style>
  .hero {
    max-width: 900px;
    margin: 0 auto;
    padding: clamp(48px, 9vw, 110px) 24px 48px;
  }
  h1 {
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  h1 em {
    font-style: normal;
    background: var(--grad-aurora);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .sub {
    margin-top: 18px;
    max-width: 480px;
    color: var(--text-2);
    font-size: 15px;
  }
  .cta {
    margin-top: 28px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
