---
interface Node {
  q: string;
  yes?: string;
  no?: string;
}
interface Props {
  nodes: Node[];
}
const { nodes } = Astro.props;
---

<div class="tree">
  {
    nodes.map((n) => (
      <div class="node">
        <div class="q">{n.q}</div>
        {n.yes && <div class="branch yes">Да → {n.yes}</div>}
        {n.no && <div class="branch no">Нет → {n.no}</div>}
      </div>
    ))
  }
</div>

<style>
  .tree {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 14px 0;
  }
  .node {
    border: 1px solid var(--glass-border);
    border-radius: var(--r-md);
    padding: 14px;
    background: var(--glass-bg);
  }
  .q {
    font-weight: 600;
    color: var(--text);
    margin-bottom: 8px;
    font-size: 14px;
  }
  .branch {
    font-size: 13px;
    padding: 6px 10px;
    border-radius: var(--r-sm);
    margin-top: 4px;
  }
  .yes {
    background: #34d39922;
    color: #34d399;
  }
  .no {
    background: #f8717122;
    color: #f87171;
  }
</style>
