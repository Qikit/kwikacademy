---
import Icon from '../ui/Icon.astro';
interface Props {
  eyebrow: string;
  title: string;
  readingMinutes: number;
}
const { eyebrow, title, readingMinutes } = Astro.props;
---

<header class="lhero">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="rt"><Icon name="clock" size={14} /> {readingMinutes} мин чтения</p>
</header>

<style>
  .lhero {
    margin-bottom: 32px;
  }
  h1 {
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 800;
    margin: 12px 0;
  }
  .rt {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-3);
  }
</style>
