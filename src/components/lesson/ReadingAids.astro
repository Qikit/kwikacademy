---
import Icon from '../ui/Icon.astro';
---

<div class="reading-bar" aria-hidden="true"><i id="readingFill"></i></div>

<button id="toTop" class="to-top" aria-label="Наверх">
  <span class="blob"></span>
  <Icon name="arrow-up" size={20} />
</button>

<script>
  const fill = document.getElementById('readingFill');
  const btn = document.getElementById('toTop');

  function onScroll() {
    const doc = document.documentElement;
    const max = doc.scrollHeight - doc.clientHeight;
    const pct = max > 0 ? (doc.scrollTop / max) * 100 : 0;
    if (fill) fill.style.width = pct + '%';
    // show bubble only near the bottom, where it won't cover the reading flow
    if (btn) btn.classList.toggle('show', pct > 78);
  }

  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });
  onScroll();
</script>

<style>
  .reading-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 200;
    background: transparent;
    pointer-events: none;
  }
  .reading-bar i {
    display: block;
    height: 100%;
    width: 0;
    background: var(--grad-aurora);
    box-shadow: 0 0 10px rgba(124, 108, 240, 0.6);
    transition: width 0.1s linear;
  }

  .to-top {
    position: fixed;
    right: clamp(16px, 4vw, 36px);
    bottom: clamp(16px, 4vw, 36px);
    z-index: 150;
    width: 52px;
    height: 52px;
    border: none;
    cursor: pointer;
    background: transparent;
    color: #fff;
    display: grid;
    place-items: center;
    opacity: 0;
    transform: translateY(16px) scale(0.8);
    pointer-events: none;
    transition: opacity 0.35s, transform 0.35s;
  }
  .to-top.show {
    opacity: 0.85;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .to-top:hover {
    opacity: 1;
  }
  .to-top :global(svg) {
    position: relative;
    z-index: 1;
  }
  .blob {
    position: absolute;
    inset: 0;
    background: var(--grad-blue-purple);
    box-shadow: 0 12px 30px -10px rgba(124, 108, 240, 0.7);
    border-radius: 42% 58% 63% 37% / 41% 44% 56% 59%;
    animation: morph 8s ease-in-out infinite;
  }
  @keyframes morph {
    0%,
    100% {
      border-radius: 42% 58% 63% 37% / 41% 44% 56% 59%;
      transform: rotate(0deg);
    }
    33% {
      border-radius: 62% 38% 41% 59% / 56% 63% 37% 44%;
      transform: rotate(8deg);
    }
    66% {
      border-radius: 38% 62% 56% 44% / 63% 38% 62% 37%;
      transform: rotate(-6deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .blob {
      border-radius: 50%;
    }
  }
</style>
