---
interface ScaleItem {
  position: number;
  label: string;
  note?: string;
}
interface Props {
  items: ScaleItem[];
  axis?: string;
  leftLabel?: string;
  rightLabel?: string;
}
const { items, axis, leftLabel, rightLabel } = Astro.props;
const clamped = items.map((it) => ({
  ...it,
  position: Math.max(0, Math.min(100, it.position)),
}));
---

<figure class="sc">
  {axis && <div class="sc-axis-name">{axis}</div>}
  <div class="sc-bar">
    <div class="sc-line"></div>
    {clamped.map((it) => (
      <div class="sc-mark" style={`left: ${it.position}%`}>
        <span class="sc-tick"></span>
        <span class="sc-label">{it.label}</span>
        {it.note && <span class="sc-note">{it.note}</span>}
      </div>
    ))}
  </div>
  {(leftLabel || rightLabel) && (
    <div class="sc-ends">
      <span>{leftLabel ?? ''}</span>
      <span>{rightLabel ?? ''}</span>
    </div>
  )}
</figure>

<style>
  .sc {
    margin: 18px 0;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-md);
    padding: 22px 22px 18px;
  }
  .sc-axis-name {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-3);
    font-family: var(--font-mono);
    margin-bottom: 14px;
    text-align: center;
  }
  .sc-bar {
    position: relative;
    height: 92px;
  }
  .sc-line {
    position: absolute;
    top: 18px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      to right,
      var(--c-blue),
      var(--c-violet, var(--c-purple, #a78bfa))
    );
    opacity: 0.45;
    border-radius: 1px;
  }
  .sc-mark {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .sc-tick {
    width: 2px;
    height: 30px;
    background: var(--c-blue);
    border-radius: 1px;
  }
  .sc-label {
    font-size: 13px;
    color: var(--text);
    font-weight: 500;
    text-align: center;
    max-width: 110px;
    line-height: 1.3;
  }
  .sc-note {
    font-size: 11px;
    color: var(--text-3);
    text-align: center;
    max-width: 110px;
  }
  .sc-ends {
    display: flex;
    justify-content: space-between;
    margin-top: 4px;
    font-size: 11px;
    color: var(--text-3);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  @media (max-width: 520px) {
    .sc-label {
      font-size: 11px;
      max-width: 70px;
    }
  }
</style>
