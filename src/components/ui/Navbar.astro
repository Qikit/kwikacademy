---
import ThemeToggle from './ThemeToggle.tsx';
import Icon from './Icon.astro';
import { withBase } from '../../lib/url';

const links = [
  { href: withBase('/'), label: 'Главная', icon: 'home' as const },
  { href: withBase('/topics'), label: 'Темы', icon: 'layers' as const },
  { href: withBase('/progress'), label: 'Прогресс', icon: 'target' as const },
];
---

<header class="bar">
  <a class="logo" href={withBase('/')}>
    <span class="logo-mark"><Icon name="graduation-cap" size={18} /></span>
    KwikAcademy
  </a>
  <nav class="pill" data-open="false" aria-label="Разделы">
    {
      links.map((l) => (
        <a href={l.href}>
          <Icon name={l.icon} size={15} />
          <span>{l.label}</span>
        </a>
      ))
    }
  </nav>
  <ThemeToggle client:load />
</header>

<script>
  // Mobile only: tapping the collapsed pill expands it (liquid-glass morph) to reveal
  // section labels. A second tap on a link navigates; a tap outside collapses.
  const pill = document.querySelector<HTMLElement>('header .pill');
  if (pill) {
    const mq = matchMedia('(max-width: 600px)');
    pill.addEventListener('click', (e) => {
      if (!mq.matches) return;
      if (pill.dataset.open !== 'true') {
        // first tap on the collapsed pill: expand instead of following the link
        const a = (e.target as HTMLElement).closest('a');
        if (a) e.preventDefault();
        pill.dataset.open = 'true';
      }
    });
    document.addEventListener('click', (e) => {
      if (!mq.matches) return;
      if (pill.dataset.open === 'true' && !pill.contains(e.target as Node)) {
        pill.dataset.open = 'false';
      }
    });
  }
</script>

<style>
  .bar {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px clamp(16px, 4vw, 40px);
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
  }
  .logo-mark {
    display: inline-flex;
    width: 30px;
    height: 30px;
    align-items: center;
    justify-content: center;
    border-radius: 9px;
    color: #fff;
    background: var(--grad-aurora);
  }
  .pill {
    display: flex;
    gap: 4px;
    padding: 6px;
    border-radius: var(--r-full);
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--glass-border);
    transition:
      padding 0.45s cubic-bezier(0.2, 0.9, 0.25, 1.1),
      gap 0.45s cubic-bezier(0.2, 0.9, 0.25, 1.1),
      box-shadow 0.35s,
      background 0.3s;
  }
  .pill a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 600;
    padding: 8px 15px;
    border-radius: var(--r-full);
    color: var(--text-2);
    transition:
      color 0.2s,
      background 0.2s,
      padding 0.4s cubic-bezier(0.2, 0.9, 0.25, 1.1);
  }
  .pill a span {
    transition:
      max-width 0.4s cubic-bezier(0.2, 0.9, 0.25, 1.1),
      opacity 0.3s,
      margin 0.4s;
    white-space: nowrap;
    overflow: hidden;
  }
  .pill a:hover {
    color: var(--c-purple);
    background: var(--track);
  }
  @media (max-width: 600px) {
    /* Pill is always absolute on mobile — same position type in both states means
       every other property (width, top, padding, gap, radius) interpolates smoothly. */
    .pill {
      position: absolute;
      top: 14px;
      right: 16px;
      box-sizing: border-box;
      overflow: hidden;
      will-change: width, top, padding;
      transition:
        width 0.5s cubic-bezier(0.2, 0.9, 0.25, 1.1),
        top 0.5s cubic-bezier(0.2, 0.9, 0.25, 1.1),
        right 0.5s cubic-bezier(0.2, 0.9, 0.25, 1.1),
        padding 0.5s cubic-bezier(0.2, 0.9, 0.25, 1.1),
        gap 0.5s cubic-bezier(0.2, 0.9, 0.25, 1.1),
        border-radius 0.5s cubic-bezier(0.2, 0.9, 0.25, 1.1),
        background 0.3s,
        box-shadow 0.3s;
    }
    .pill a {
      padding: 9px;
      transition:
        padding 0.4s cubic-bezier(0.2, 0.9, 0.25, 1.1),
        border-radius 0.3s,
        color 0.2s,
        background 0.2s;
    }
    /* Collapsed: compact icon strip anchored to the right of the bar, leaving
       room for the theme toggle (38px button + 12px gap). */
    .pill[data-open='false'] {
      right: 66px;
      width: 152px;
      padding: 6px;
      gap: 4px;
      border-radius: var(--r-full);
      flex-direction: row;
      justify-content: flex-end;
    }
    .pill[data-open='false'] a span {
      max-width: 0;
      opacity: 0;
      margin-left: -7px;
    }
    /* Expanded: full-width vertical menu just below the navbar. */
    .pill[data-open='true'] {
      width: calc(100vw - 32px);
      top: 62px;
      padding: 10px;
      gap: 4px;
      border-radius: 20px;
      flex-direction: column;
      align-items: stretch;
      background: color-mix(in srgb, var(--glass-bg) 96%, transparent);
      box-shadow: 0 22px 50px -16px rgba(0, 0, 0, 0.45);
    }
    .pill[data-open='true'] a {
      justify-content: flex-start;
      padding: 12px 14px;
      border-radius: 14px;
    }
    .pill[data-open='true'] a span {
      max-width: 240px;
      opacity: 1;
      margin-left: 0;
      transition: max-width 0.45s cubic-bezier(0.2, 0.9, 0.25, 1.1) 0.12s, opacity 0.3s 0.18s;
    }
  }
</style>
