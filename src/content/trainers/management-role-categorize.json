    ],
    "items": [
      { "text": "Провести 1-on-1 с уставшим джуном", "category": "people", "explain": "Состояние и рост человека — область «люди»." },
      { "text": "Дать сотруднику обратную связь по затянутому ревью", "category": "people", "explain": "Поведение и развитие сотрудника — «люди»." },
      { "text": "Собеседовать кандидата в команду", "category": "people", "explain": "Найм — часть работы с людьми." },
      { "text": "Обсудить с сотрудником план роста на полгода", "category": "people", "explain": "Развитие человека — «люди»." },
      { "text": "Настроить регулярное планирование спринта", "category": "process", "explain": "Как команда работает регулярно — «процессы»." },
      { "text": "Описать, как команда принимает и оформляет задачи", "category": "process", "explain": "Правила совместной работы — «процессы»." },
      { "text": "Разобрать повторяющийся инцидент, чтобы чинил не только ты", "category": "process", "explain": "Налаживание устойчивого процесса и знания — «процессы» (и снижение bus factor)." },
      { "text": "Ввести ретро после каждого релиза", "category": "process", "explain": "Регулярный ритм улучшений — «процессы»." },
      { "text": "Решить, какие две фичи режем из релиза", "category": "decisions", "explain": "Выбор «что не делаем» при ограничениях — «решения»." },
      { "text": "Определить приоритет между двумя срочными задачами", "category": "decisions", "explain": "Приоритизация в конфликте — «решения»." },
      { "text": "Выбрать технологию, зная, что откатить будет дорого", "category": "decisions", "explain": "Необратимый выбор в неопределённости — «решения»." },
      { "text": "Решить, брать ли срочный запрос в обход плана", "category": "decisions", "explain": "Выбор приоритета и границы — «решения»." }
    ]
  }
