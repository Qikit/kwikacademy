---
import BaseLayout from './BaseLayout.astro';
import LessonHero from '../components/lesson/LessonHero.astro';
import LessonComplete from '../components/lesson/LessonComplete.tsx';
import ReadingAids from '../components/lesson/ReadingAids.astro';

interface Props {
  title: string;
  eyebrow: string;
  readingMinutes: number;
  slug: string;
  nextHref?: string;
}
const { title, eyebrow, readingMinutes, slug, nextHref } = Astro.props;
---

<BaseLayout title={`${title} — KwikAcademy`}>
  <ReadingAids />
  <article class="lesson">
    <LessonHero eyebrow={eyebrow} title={title} readingMinutes={readingMinutes} />
    <div class="prose"><slot /></div>
    <LessonComplete client:visible slug={slug} nextHref={nextHref} />
  </article>
</BaseLayout>

<style>
  .lesson {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px 96px;
  }
  .prose :global(p) {
    color: var(--text-2);
    margin: 12px 0;
    line-height: 1.8;
  }
  .prose :global(h2) {
    font-size: 22px;
    margin: 32px 0 14px;
  }
  .prose :global(h3) {
    font-size: 16px;
    margin: 22px 0 10px;
  }
  .prose :global(strong) {
    color: var(--text);
  }
  .prose :global(ul),
  .prose :global(ol) {
    color: var(--text-2);
    margin: 12px 0 12px 20px;
    line-height: 1.8;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 6px;
    padding: 2px 6px;
  }
</style>
