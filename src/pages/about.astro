---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="О проекте — KwikAcademy">
  <section style="max-width:680px;margin:0 auto;padding:48px 24px 96px;">
    <p class="eyebrow">О проекте</p>
    <h1 style="font-size:clamp(32px,6vw,52px);font-weight:800;margin:12px 0 24px;">KwikAcademy</h1>
    <p style="color:var(--text-2);line-height:1.8;">
      Личная некоммерческая платформа обучающих материалов и тренажёров. Без регистрации и без оплаты.
      Весь прогресс хранится прямо в браузере на твоём устройстве — его можно экспортировать и перенести.
    </p>
  </section>
</BaseLayout>
