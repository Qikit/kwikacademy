---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Roadmap from '../../components/course/Roadmap.astro';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({ params: { topic: course.id }, props: { course } }));
}

const { course } = Astro.props;

const lessons = (await getCollection('lessons'))
  .filter((l) => l.data.course === course.id)
  .sort((a, b) => a.data.order - b.data.order);
const nodes = lessons.map((l) => ({
  slug: l.id,
  title: l.data.title,
  order: l.data.order,
  href: withBase(`/learn/${course.id}/${l.id}`),
  phase: l.data.phase,
  placeholder: l.data.placeholder,
}));

const trainers = (await getCollection('trainers')).filter((t) => t.data.course === course.id);

const trainersByLesson = new Map<string, typeof trainers>();
for (const t of trainers) {
  const key = t.data.lesson ?? '__loose__';
  const bucket = trainersByLesson.get(key) ?? [];
  bucket.push(t);
  trainersByLesson.set(key, bucket);
}

type TrainerGroup = { id: string; title: string; items: typeof trainers };
const groups: TrainerGroup[] = [];
for (const l of lessons) {
  const items = trainersByLesson.get(l.id);
  if (items && items.length) groups.push({ id: l.id, title: l.data.title, items });
}
const loose = trainersByLesson.get('__loose__');
if (loose && loose.length) groups.push({ id: '__loose__', title: 'Без привязки к уроку', items: loose });

const KIND_LABEL: Record<string, string> = {
  flashcards: 'Карточки',
  match: 'Match',
  categorize: 'Категории',
  quiz: 'Тест',
  cloze: 'Пропуски',
  ordering: 'Порядок',
};
---

<BaseLayout title={`${course.data.title} — KwikAcademy`}>
  <section class="topic" data-course={course.id}>
    <p class="eyebrow">{course.data.subtitle}</p>
    <h1>{course.data.title}</h1>
    <p class="desc">{course.data.description}</p>

    <h2>Дорожная карта</h2>
    {nodes.length > 0 ? <Roadmap nodes={nodes} /> : <p class="empty">Уроки скоро появятся.</p>}

    <h2>Тренажёры</h2>
    {
      groups.length > 0 ? (
        <div class="trainer-groups">
          {groups.map((g, gi) => (
            <details class="trainer-group" open={gi === 0} data-group={g.id}>
              <summary class="trainer-group-summary">
                <span class="trainer-group-caret" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
                </span>
                <span class="trainer-group-title">{g.title}</span>
                <span class="trainer-group-meta">
                  <span class="trainer-group-count">{g.items.length} тр.</span>
                  <span class="trainer-group-progress" data-group-progress={g.id} hidden>
                    <span class="trainer-group-progress-text" />
                  </span>
                </span>
              </summary>
              <div class="kc-trainer-grid">
                {g.items.map((t) => (
                  <a
                    class="kc-trainer-card"
                    href={withBase(`/practice/${course.id}/${t.id}`)}
                    data-trainer={t.id}
                  >
                    <span class="kc-trainer-kind">{KIND_LABEL[t.data.data.type] ?? t.data.data.type}</span>
                    <span class="kc-trainer-title">{t.data.title}</span>
                    <span class="kc-trainer-hint">{t.data.description}</span>
                    <span class="kc-trainer-arrow" aria-hidden="true">→</span>
                    <span class="kc-trainer-badge" aria-label="результат">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                      <b class="tscore" />
                    </span>
                  </a>
                ))}
              </div>
            </details>
          ))}
        </div>
      ) : (
        <p class="empty">Тренажёры скоро появятся.</p>
      )
    }
  </section>

  <script>
    import { hydrateRoadmap, hydrateTrainerList } from '../../lib/progress/hydrate';
    // ClientRouter swaps the DOM without re-executing module scripts, so we
    // re-run hydration on every page-load event (covers first load + swaps).
    function run() {
      hydrateRoadmap();
      hydrateTrainerList().then(() => {
        document.querySelectorAll<HTMLElement>('[data-group]').forEach((group) => {
          const cards = group.querySelectorAll<HTMLElement>('[data-trainer]');
          const done = Array.from(cards).filter((c) => c.dataset.done === 'true').length;
          if (done === 0) return;
          const wrap = group.querySelector<HTMLElement>('[data-group-progress]');
          const text = group.querySelector<HTMLElement>('.trainer-group-progress-text');
          if (!wrap || !text) return;
          wrap.hidden = false;
          text.textContent = `${done} / ${cards.length}`;
          if (done === cards.length) wrap.dataset.full = 'true';
        });
      });
    }
    document.addEventListener('astro:page-load', run);
  </script>
</BaseLayout>

<style>
  .topic {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px 96px;
  }
  h1 {
    font-size: clamp(32px, 6vw, 52px);
    font-weight: 800;
    margin: 12px 0;
  }
  .desc {
    color: var(--text-2);
    max-width: 520px;
    margin-bottom: 48px;
  }
  h2 {
    font-size: 20px;
    margin: 48px 0 24px;
  }
  .empty {
    color: var(--text-3);
    font-size: 14px;
  }
  .trainer-groups {
    display: grid;
    gap: 12px;
  }
  .trainer-group {
    border: 1px solid var(--glass-border);
    border-radius: var(--r-md);
    background: var(--glass-bg);
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .trainer-group[open] {
    border-color: rgba(96, 165, 250, 0.35);
  }
  .trainer-group-summary {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .trainer-group-summary::-webkit-details-marker {
    display: none;
  }
  .trainer-group-summary::marker {
    display: none;
  }
  .trainer-group-summary:hover {
    background: rgba(255, 255, 255, 0.03);
  }
  .trainer-group-caret {
    display: inline-flex;
    color: var(--text-3);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .trainer-group[open] .trainer-group-caret {
    transform: rotate(90deg);
    color: var(--c-blue);
  }
  .trainer-group-title {
    flex: 1;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }
  .trainer-group-meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .trainer-group-count {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-3);
  }
  .trainer-group-progress {
    display: inline-flex;
    align-items: center;
    padding: 3px 9px;
    border-radius: var(--r-full);
    background: rgba(96, 165, 250, 0.16);
    color: var(--c-blue);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
  }
  .trainer-group-progress[data-full='true'] {
    background: rgba(52, 211, 153, 0.18);
    color: #34d399;
  }
  .trainer-group .kc-trainer-grid {
    margin: 0;
    padding: 4px 18px 18px;
  }
  .kc-trainer-card .kc-trainer-badge {
    display: none;
  }
  .kc-trainer-card[data-done='true'] {
    border-color: rgba(52, 211, 153, 0.5);
  }
  .kc-trainer-card[data-done='true'] .kc-trainer-arrow {
    display: none;
  }
  .kc-trainer-card[data-done='true'] .kc-trainer-badge {
    grid-area: arrow;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: #34d399;
    background: rgba(52, 211, 153, 0.14);
    padding: 5px 10px;
    border-radius: var(--r-full);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    height: fit-content;
    align-self: center;
  }
  @media (max-width: 640px) {
    .trainer-group-summary {
      padding: 12px 14px;
    }
    .trainer-group .kc-trainer-grid {
      padding: 4px 12px 14px;
    }
  }
</style>
